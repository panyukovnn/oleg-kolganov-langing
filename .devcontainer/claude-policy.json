{
  "permissions": {
    "deny": [
      "Bash(git pull:*)",
      "Bash(git rebase:*)",
      "Bash(git commit --amend:*)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --keep:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --delete:*)",
      "Bash(git push -d:*)",
      "Bash(git branch -d:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch --delete:*)",
      "Bash(git branch -m:*)",
      "Bash(git branch -M:*)",
      "Bash(git branch --move:*)",
      "Bash(git tag -d:*)",
      "Bash(git tag --delete:*)",
      "Bash(git checkout -B:*)",
      "Bash(git checkout --orphan:*)",
      "Bash(git switch -C:*)",
      "Bash(git switch --orphan:*)",
      "Bash(git update-ref:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git replace:*)",
      "Bash(git reflog expire:*)",
      "Bash(git reflog delete:*)",
      "Bash(git gc --aggressive:*)",
      "Bash(git gc --prune=now:*)",
      "Bash(gh pr merge:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.devcontainer/git-policy-hook.py"
          }
        ]
      }
    ]
  }
}